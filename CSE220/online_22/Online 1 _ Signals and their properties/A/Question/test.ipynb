   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "t = np.linspace(-5, 5, 1000)\n",
    "y = np.sin(2 * np.pi * 0.5 * t) + 0.5 * np.sin(2 * np.pi * 1.5 * t)\n",
    "\n",
    "plt.axhline(y = 0)\n",
    "plt.axvline(x = 0)\n",
    "plt.plot(t, y)"
   ]
  }
